FROM node:24.18-trixie-slim AS frontend-build

WORKDIR /opt/frontend

COPY frontend/package*.json ./
RUN npm ci --prefer-offline --no-audit --no-fund

COPY frontend/ ./
RUN npm run start:build


FROM node:24.18-trixie-slim AS backend-build

WORKDIR /opt/app

ENV PRISMA_CLI_BINARY_TARGETS=debian-openssl-3.0.x,linux-arm64-openssl-3.0.x

COPY backend/package*.json ./
COPY backend/prisma ./prisma
COPY backend/prisma.config.ts ./prisma.config.ts
COPY backend/patches ./patches

RUN npm ci --prefer-offline --no-audit --no-fund

COPY backend/ ./
RUN npm run migrate:generate && npm run build && npm prune --omit=dev


FROM node:24.18-trixie-slim

WORKDIR /opt/app

ENV REMNAWAVE_BRANCH=test \
    PRISMA_HIDE_UPDATE_MESSAGE=true \
    PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 \
    PM2_DISABLE_VERSION_CHECK=true \
    NODE_OPTIONS=--max-old-space-size=4096

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/* \
    && npm install pm2 -g

COPY --from=backend-build /opt/app/dist ./dist
COPY --from=frontend-build /opt/frontend/dist ./frontend
COPY --from=backend-build /opt/app/prisma ./prisma
COPY --from=backend-build /opt/app/node_modules ./node_modules
COPY backend/configs /var/lib/remnawave/configs
COPY backend/package*.json ./
COPY backend/prisma.config.ts ./prisma.config.ts
COPY backend/ecosystem.config.js ./
COPY backend/docker-entrypoint.sh ./

RUN chmod +x docker-entrypoint.sh

ENTRYPOINT ["/bin/sh", "docker-entrypoint.sh"]
CMD ["pm2-runtime", "start", "ecosystem.config.js", "--env", "production"]
